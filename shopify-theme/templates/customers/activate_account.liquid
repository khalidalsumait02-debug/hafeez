<div class="pagehead"><div class="wrap"><div class="eyebrow">Account</div><h1>Activate account</h1></div></div>
<div class="legaldoc">
  {%- form 'activate_customer_password' -%}
    {{ form.errors | default_errors }}
    <div class="opt"><label>Password</label><input type="password" name="customer[password]" required style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <div class="opt"><label>Confirm password</label><input type="password" name="customer[password_confirmation]" required style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <button type="submit" class="btn btn--green">Activate</button>
    <button type="submit" name="decline" class="btn btn--w btn--out" style="color:var(--ink);border-color:var(--line)">Decline</button>
  {%- endform -%}
</div>
