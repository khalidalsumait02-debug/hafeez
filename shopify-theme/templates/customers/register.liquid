<div class="pagehead"><div class="wrap"><div class="eyebrow">Account</div><h1>Create account</h1></div></div>
<div class="legaldoc">
  {%- form 'create_customer' -%}
    {{ form.errors | default_errors }}
    <div class="opt"><label>First name</label><input type="text" name="customer[first_name]" style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <div class="opt"><label>Last name</label><input type="text" name="customer[last_name]" style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <div class="opt"><label>Email</label><input type="email" name="customer[email]" required style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <div class="opt"><label>Password</label><input type="password" name="customer[password]" required style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <button type="submit" class="btn btn--green">Create</button>
  {%- endform -%}
  <p style="margin-top:18px">Already have an account? <a href="{{ routes.account_login_url }}">Log in</a></p>
</div>
