<div class="pagehead"><div class="wrap"><div class="eyebrow">Account</div><h1>Reset password</h1></div></div>
<div class="legaldoc">
  {%- form 'reset_customer_password' -%}
    {{ form.errors | default_errors }}
    <div class="opt"><label>New password</label><input type="password" name="customer[password]" required style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <div class="opt"><label>Confirm password</label><input type="password" name="customer[password_confirmation]" required style="width:100%;padding:12px 16px;border:1.5px solid var(--line);border-radius:10px"></div>
    <button type="submit" class="btn btn--green">Reset</button>
  {%- endform -%}
</div>
