<section class="sec wrap">
  <div class="head">
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a href="{{ section.settings.link_url | default: collections[section.settings.collection].url | default: '#' }}" class="lk">{{ section.settings.link_label }}</a>
    {%- endif -%}
  </div>

  {%- assign layout_class = 'pscroll' -%}
  {%- if section.settings.layout == 'grid' -%}{%- assign layout_class = 'pgrid' -%}{%- endif -%}

  <div class="{{ layout_class }}">
    {%- assign col = collections[section.settings.collection] -%}
    {%- if col != blank and col.products.size > 0 -%}
      {%- for product in col.products limit: section.settings.product_limit -%}
        {%- if forloop.first and section.settings.first_badge != blank -%}
          {%- render 'product-card', product: product, badge: section.settings.first_badge -%}
        {%- else -%}
          {%- render 'product-card', product: product -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.product_limit) -%}
        <div class="card">
          <div class="im"><div class="imgwrap">{{ 'product-' | append: i | placeholder_svg_tag: 'media' }}</div></div>
          <h3>Example product</h3>
          <div class="meta">Brand</div>
          <div class="pr">{{ 1000 | money }}</div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "carousel", "label": "Carousel" },
        { "value": "grid", "label": "Grid" }
      ],
      "default": "carousel"
    },
    { "type": "text", "id": "first_badge", "label": "Badge on first product", "default": "Best Seller" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop all" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
