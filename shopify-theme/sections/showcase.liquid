<section class="showcase{% if section.settings.reverse %} r{% endif %}{% if section.settings.light %} light{% endif %}">
  <div class="media-wrap">
    <div class="imgwrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.heading | escape, widths: '750,1100,1600' }}
      {%- endif -%}
    </div>
  </div>
  <div class="wrap">
    <div class="card2">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
      {%- if section.settings.button_label != blank -%}<a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--w">{{ section.settings.button_label }}</a>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Showcase band",
  "settings": [
    { "type": "checkbox", "id": "reverse", "label": "Content on right", "default": false },
    { "type": "checkbox", "id": "light", "label": "Light overlay", "default": false },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Play anywhere" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beach. Chalet. Backyard." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Pack it in the car and turn any patch of sand or grass into the most competitive game of the day." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "Showcase band" }]
}
{% endschema %}
