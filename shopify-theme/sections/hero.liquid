<section class="hero{% if section.settings.image == blank %} noimg{% endif %}" id="hero-{{ section.id }}">
  <div class="bg">
    {%- if section.settings.image != blank -%}
      <div class="imgwrap">
        {{ section.settings.image | image_url: width: 2200 | image_tag:
          loading: 'eager', fetchpriority: 'high', alt: section.settings.heading,
          widths: '750,1100,1600,2200' }}
      </div>
    {%- endif -%}
  </div>
  <div class="in">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1>{{ section.settings.heading }}</h1>
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
    <div class="cta">
      {%- if section.settings.button1_label != blank -%}
        <a href="{{ section.settings.button1_url | default: '#' }}" class="btn btn--green">{{ section.settings.button1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button2_label != blank -%}
        <a href="{{ section.settings.button2_url | default: '#' }}" class="btn btn--glass">{{ section.settings.button2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hafeez · Kuwait's lifestyle store" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The ride. The game. The summer." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Official Harley-Davidson® gear, the viral PaddleSmash game, and the brands that own Kuwait's summer — all in one place, shipped across the GCC." },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "button1_label", "label": "Button 1 label", "default": "Shop new arrivals" },
    { "type": "url", "id": "button1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "button2_label", "label": "Button 2 label", "default": "Explore PaddleSmash" },
    { "type": "url", "id": "button2_url", "label": "Button 2 URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
