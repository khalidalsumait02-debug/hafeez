<section class="sec wrap">
  <div class="head">
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a href="{{ section.settings.link_url | default: '#' }}" class="lk">{{ section.settings.link_label }}</a>
    {%- endif -%}
  </div>
  <div class="scroller">
    {%- for block in section.blocks -%}
      {%- liquid
        assign b_image = block.settings.image
        assign b_label = block.settings.label
        assign b_url = block.settings.link
        if block.settings.collection != blank
          assign col = collections[block.settings.collection]
          if b_image == blank
            assign b_image = col.featured_image
          endif
          if b_label == blank
            assign b_label = col.title
          endif
          if b_url == blank
            assign b_url = col.url
          endif
        endif
      -%}
      <a href="{{ b_url | default: '#' }}" class="cat{% if b_image == blank %} noimg{% endif %}" {{ block.shopify_attributes }}>
        <div class="imgwrap">
          {%- if b_image != blank -%}
            {{ b_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: b_label, widths: '300,500,700' }}
          {%- endif -%}
        </div>
        <span class="lab">{{ b_label }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category scroller",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection (optional)" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "label", "label": "Label override" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Category scroller",
      "blocks": [
        { "type": "category", "settings": { "label": "New In" } },
        { "type": "category", "settings": { "label": "Men" } },
        { "type": "category", "settings": { "label": "Women" } },
        { "type": "category", "settings": { "label": "Headwear" } },
        { "type": "category", "settings": { "label": "Accessories" } },
        { "type": "category", "settings": { "label": "Sale" } }
      ]
    }
  ]
}
{% endschema %}
