<section class="ctaband{% if section.settings.dark %} dark{% endif %}">
  <div class="wrap">
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
    {%- if section.settings.button_label != blank -%}<a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--w">{{ section.settings.button_label }}</a>{%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "CTA band",
  "settings": [
    { "type": "checkbox", "id": "dark", "label": "Dark style", "default": false },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Don't be the only chalet without one" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "The Complete Set ships across the GCC and packs down to travel. Get yours before the weekend." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Complete Set" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "CTA band" }]
}
{% endschema %}
