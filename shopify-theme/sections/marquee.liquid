<div class="marquee{% if section.settings.dark %} dark{% endif %}" aria-hidden="true">
  <div class="marquee__track">
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}<span>{{ block.settings.text }}</span>{%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "checkbox", "id": "dark", "label": "Dark style", "default": false }
  ],
  "blocks": [
    { "type": "item", "name": "Phrase", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "Bump · Set · Smash" } ] }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "Bump · Set · Smash" } },
        { "type": "item", "settings": { "text": "The viral chalet game" } },
        { "type": "item", "settings": { "text": "Pickleball meets spikeball" } },
        { "type": "item", "settings": { "text": "2 minutes to learn" } },
        { "type": "item", "settings": { "text": "In stock in Kuwait" } }
      ]
    }
  ]
}
{% endschema %}
