<section class="split {{ section.settings.color_scheme }}{% if section.settings.flip %} flip{% endif %}" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}>
  <div class="img{% if section.settings.image == blank %} noimg{% endif %}">
    <div class="imgwrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: section.settings.heading | escape, widths: '600,900,1400' }}
      {%- endif -%}
    </div>
  </div>
  <div class="copy">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}

    {%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
    {%- assign point_blocks = section.blocks | where: 'type', 'point' -%}

    {%- if stat_blocks.size > 0 -%}
      <div class="stats">
        {%- for block in stat_blocks -%}
          <div {{ block.shopify_attributes }}><div class="n">{{ block.settings.number }}</div><div class="l">{{ block.settings.label }}</div></div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if point_blocks.size > 0 -%}
      <ul class="pts">
        {%- for block in point_blocks -%}
          <li {{ block.shopify_attributes }}><b>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</b><span>{{ block.settings.text }}</span></li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div><a href="{{ section.settings.button_url | default: '#' }}" class="btn {{ section.settings.button_style }}">{{ section.settings.button_label }}</a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Split feature",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "", "label": "Light" },
        { "value": "green", "label": "Green" },
        { "value": "darkgreen", "label": "Dark green" }
      ],
      "default": "green"
    },
    { "type": "checkbox", "id": "flip", "label": "Image on right", "default": false },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The viral one" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everyone's playing PaddleSmash" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Part pickleball, part spikeball, all addictive — the game taking over Kuwait's chalets and beaches." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop PaddleSmash" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "", "label": "Dark" },
        { "value": "btn--green", "label": "Green" },
        { "value": "btn--w", "label": "White" }
      ],
      "default": ""
    },
    { "type": "text", "id": "anchor", "label": "Anchor id (optional)" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "2 min" },
        { "type": "text", "id": "label", "label": "Label", "default": "To learn" }
      ]
    },
    {
      "type": "point",
      "name": "Numbered point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "100% authentic, officially licensed merchandise." }
      ]
    }
  ],
  "presets": [{ "name": "Split feature" }]
}
{% endschema %}
