[
  {
    "name": "theme_info",
    "theme_name": "Hafeez",
    "theme_version": "1.0.0",
    "theme_author": "Hafeez International",
    "theme_documentation_url": "https://khalidalsumait02-debug.github.io/hafeez/",
    "theme_support_url": "https://khalidalsumait02-debug.github.io/hafeez/"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_height",
        "min": 24,
        "max": 70,
        "step": 2,
        "unit": "px",
        "label": "Logo height",
        "default": 42
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_green",
        "label": "Brand green",
        "default": "#26d07c"
      },
      {
        "type": "color",
        "id": "color_green_dark",
        "label": "Brand green (dark)",
        "default": "#005844"
      },
      {
        "type": "color",
        "id": "color_ink",
        "label": "Ink / text",
        "default": "#0a0c0b"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (per-page override)",
        "default": "#26d07c"
      },
      {
        "type": "color",
        "id": "color_accent_ink",
        "label": "Accent text",
        "default": "#0a0c0b"
      }
    ]
  },
  {
    "name": "Currency format",
    "settings": [
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "label": "Show currency codes",
        "default": true,
        "info": "Cart and checkout prices always show currency codes."
      }
    ]
  }
]
